<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Root Calculator - Minimal</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
        }
        body {
            background-color: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #ffffff;
            padding: 20px;
        }
        .calculator {
            width: 100%;
            max-width: 380px;
            height: 85vh; 
            max-height: 650px;
            background-color: #000000;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .display-section {
            text-align: right;
            padding: 10px 0;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }
        .history-item {
            font-size: 1.1rem;
            color: #7d7d7d;
            margin-bottom: 12px;
            font-weight: 300;
            min-height: 26px;
        }
        .history-item span {
            color: #ff9f0a; 
            font-weight: 500;
        }
        .input-container {
            width: 100%;
            border-bottom: 2px solid #ffffff; 
            padding-bottom: 8px;
            margin-top: auto; 
            margin-bottom: 40px;
        }
        .input-field {
            width: 100%;
            background: transparent;
            border: none;
            color: #ffffff;
            font-size: 3rem;
            font-weight: 300;
            text-align: right;
            outline: none;
            padding: 0;
        }
        .input-field::-webkit-outer-spin-button,
        .input-field::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .input-field::placeholder {
            color: #2c2c2e;
        }
        .btn-calc {
            width: 100%;
            background-color: #ff9f0a;
            color: #ffffff;
            border: none;
            font-size: 1.3rem;
            font-weight: 500;
            padding: 18px;
            border-radius: 16px;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.1s;
            -webkit-tap-highlight-color: transparent;
        }
        .btn-calc:active {
            background-color: #cc7f08;
            transform: scale(0.98);
        }
        
        /* สไตล์ของตัวหนังสือ Rootey เรืองแสงด้านล่างปุ่ม */
        .footer-logo {
            text-align: center;
            font-size: 1rem;
            font-weight: 300;
            letter-spacing: 2px;
            color: #ffffff;
            margin-top: 20px;
            /* ใช้ text-shadow เพื่อสร้างเอฟเฟกต์เรืองแสงสีขาวนวล */
            text-shadow: 0 0 4px rgba(255, 255, 255, 0.6), 
                         0 0 12px rgba(255, 255, 255, 0.4);
            opacity: 0.85;
        }
    </style>
</head>
<body>

<div class="calculator">
    <div class="display-section">
        <div class="history-item" id="sqrt-row"></div>
        <div class="history-item" id="cube-row"></div>
        
        <div class="input-container">
            <input type="number" id="numInput" class="input-field" placeholder="0" inputmode="decimal" oninput="calculate()">
        </div>
    </div>

    <div>
        <button class="btn-calc" onclick="clearAll()">Clear</button>
        <div class="footer-logo">Rootey</div>
    </div>
</div>

<script>
function formatNumber(num) {
    if (Number.isInteger(num)) {
        return num.toLocaleString();
    } else {
        return Number(num.toFixed(6)).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 6});
    }
}

function calculate() {
    const inputVal = document.getElementById('numInput').value;
    const sqrtRow = document.getElementById('sqrt-row');
    const cubeRow = document.getElementById('cube-row');
    
    if (inputVal === '') {
        sqrtRow.innerHTML = '';
        cubeRow.innerHTML = '';
        return;
    }

    const num = parseFloat(inputVal);
    
    if (num < 0) {
        sqrtRow.innerHTML = `√${inputVal} = <span>หาค่าไม่ได้</span>`;
    } else {
        const sqrtVal = Math.sqrt(num);
        sqrtRow.innerHTML = `√${formatNumber(num)} = <span>${formatNumber(sqrtVal)}</span>`;
    }

    let cubeVal;
    if (num < 0) {
        cubeVal = -Math.pow(Math.abs(num), 1/3);
    } else {
        cubeVal = Math.pow(num, 1/3);
    }
    cubeVal = Math.round(cubeVal * 1e12) / 1e12; 
    
    cubeRow.innerHTML = `³√${formatNumber(num)} = <span>${formatNumber(cubeVal)}</span>`;
}

function clearAll() {
    document.getElementById('numInput').value = '';
    document.getElementById('sqrt-row').innerHTML = '';
    document.getElementById('cube-row').innerHTML = '';
    document.getElementById('numInput').focus();
}
</script>

</body>
</html>
